@page "/Profile/{userName}"

@attribute [Authorize]

<PageTitle>الصفحة الشخصية</PageTitle>

<TopMenu></TopMenu>

<div class="profile">
    <div class="my-container">
        <h1 class="main-title">مـعـلـومـاتـك</h1>
        <div class="box">
            <div class="info">
                <div class="first-name">
                    <h6>الاسـم الأول : </h6>
                    <h3>@user.FirstName</h3>
                </div>
                <div class="last-name">
                    <h6>الاسـم الأخـيـر : </h6>
                    <h3>@user.LastName </h3>
                </div>
                <div class="user-name">
                    <h6>الاسـم الـشـخـصـي : </h6>
                    <h3>@user.UserName</h3>
                </div>    
                <div class="email">
                    <h6>الـبـريـد الإلـكـتـرونـي : </h6>
                    <h3>@user.Email</h3>
                </div>
            </div>
        </div>
    </div>
</div>
